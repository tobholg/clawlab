// Relai - Multi-stakeholder Project Management
// Prisma Schema - Recursive Item Model

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ORGANIZATION
// ============================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members    OrganizationMember[]
  workspaces Workspace[]

  @@map("organizations")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole  @default(MEMBER)
  joinedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

// ============================================
// USER & AUTH
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Current focus
  currentFocusItemId    String?
  currentFocusStartedAt DateTime?

  // Relations
  ownedItems          Item[]               @relation("OwnedItems")
  assignedItems       ItemAssignment[]
  stakeholderItems    ItemStakeholder[]
  activities          Activity[]
  comments            Comment[]
  workspaceMembers    WorkspaceMember[]
  organizationMembers OrganizationMember[]
  magicLinkTokens     MagicLinkToken[]
  focusSessions       FocusSession[]
  currentFocusItem    Item?                @relation("CurrentFocus", fields: [currentFocusItemId], references: [id])
  channelMembers      ChannelMember[]
  messages            Message[]
  reactions           Reaction[]

  @@map("users")
}

model MagicLinkToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
  @@map("magic_link_tokens")
}

// ============================================
// WORKSPACE (Container for Items)
// ============================================

model Workspace {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String   @unique
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      WorkspaceMember[]
  items        Item[]
  channels     Channel[]

  @@index([organizationId])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ============================================
// ITEM (Recursive Task/Project Model)
// ============================================

model Item {
  id          String   @id @default(cuid())
  workspaceId String
  parentId    String?  // null = root item (project level)
  ownerId     String?  // Single owner responsible for the item
  
  // Core fields
  title       String
  description String?
  category    String?  // Engineering, Design, Marketing, etc.
  
  // Status & Progress
  status      ItemStatus @default(TODO)
  subStatus   String?    // Sub-state within status (e.g., 'scoping', 'review')
  progress    Int        @default(0) // 0-100
  
  // Scheduling
  dueDate     DateTime?
  startDate   DateTime?
  
  // AI-assisted fields
  confidence  Int        @default(70) // 0-100, AI-estimated completion likelihood
  
  // Timestamps for temperature calculation
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastActivityAt DateTime @default(now())
  
  // Relations
  workspace      Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent         Item?             @relation("ItemHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       Item[]            @relation("ItemHierarchy")
  owner          User?             @relation("OwnedItems", fields: [ownerId], references: [id])
  assignees      ItemAssignment[]
  stakeholders   ItemStakeholder[]
  blockedBy      ItemDependency[]  @relation("BlockedItem")
  blocks         ItemDependency[]  @relation("BlockingItem")
  activities     Activity[]
  comments       Comment[]
  focusSessions  FocusSession[]
  currentFocusBy User[]            @relation("CurrentFocus")
  channel        Channel?          // One project = one channel

  @@index([workspaceId])
  @@index([parentId])
  @@index([ownerId])
  @@index([status])
  @@index([lastActivityAt])
  @@map("items")
}

model ItemAssignment {
  id         String   @id @default(cuid())
  itemId     String
  userId     String
  assignedAt DateTime @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([itemId, userId])
  @@map("item_assignments")
}

model ItemStakeholder {
  id     String @id @default(cuid())
  itemId String
  userId String

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([itemId, userId])
  @@map("item_stakeholders")
}

model ItemDependency {
  id             String @id @default(cuid())
  blockedItemId  String
  blockingItemId String

  blockedItem  Item @relation("BlockedItem", fields: [blockedItemId], references: [id], onDelete: Cascade)
  blockingItem Item @relation("BlockingItem", fields: [blockingItemId], references: [id], onDelete: Cascade)

  @@unique([blockedItemId, blockingItemId])
  @@map("item_dependencies")
}

enum ItemStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  PAUSED
  DONE
}

// ============================================
// FOCUS TRACKING
// ============================================

model FocusSession {
  id        String    @id @default(cuid())
  userId    String
  itemId    String
  startedAt DateTime  @default(now())
  endedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([itemId])
  @@index([startedAt])
  @@map("focus_sessions")
}

// ============================================
// ACTIVITY & COMMENTS
// ============================================

model Activity {
  id        String       @id @default(cuid())
  itemId    String
  userId    String
  type      ActivityType
  oldValue  String?
  newValue  String?
  metadata  Json?
  createdAt DateTime     @default(now())

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([createdAt])
  @@map("activities")
}

model Comment {
  id              String   @id @default(cuid())
  itemId          String
  userId          String
  parentCommentId String?  // For nested replies
  content         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  item     Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  @@index([itemId])
  @@index([parentCommentId])
  @@map("comments")
}

enum ActivityType {
  CREATED
  UPDATED
  STATUS_CHANGE
  PROGRESS_UPDATE
  ASSIGNMENT
  COMMENT
  DEPENDENCY_ADDED
  DEPENDENCY_REMOVED
}

// ============================================
// CHANNELS & MESSAGING
// ============================================

enum ChannelType {
  WORKSPACE // #general, #off-topic
  PROJECT   // Auto-linked to project
  EXTERNAL  // Has external stakeholders
  CUSTOM    // User-created
}

enum ChannelVisibility {
  PUBLIC   // Anyone in workspace can join
  PRIVATE  // Invite only
  EXTERNAL // Has external users
}

enum ChannelRole {
  OWNER
  ADMIN
  MEMBER
  GUEST // External users
}

model Channel {
  id          String   @id @default(cuid())
  workspaceId String
  parentId    String? // For nested channels
  projectId   String? @unique // If linked to a project (one project = one channel)

  name        String  // Slug: "general", "q4-product-launch"
  displayName String? // Pretty name override
  description String?
  type        ChannelType       @default(CUSTOM)
  visibility  ChannelVisibility @default(PUBLIC)

  inheritMembers Boolean @default(true)
  archived       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent    Channel?        @relation("ChannelHierarchy", fields: [parentId], references: [id])
  children  Channel[]       @relation("ChannelHierarchy")
  project   Item?           @relation(fields: [projectId], references: [id])
  members   ChannelMember[]
  messages  Message[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([parentId])
  @@index([projectId])
  @@map("channels")
}

model ChannelMember {
  id         String      @id @default(cuid())
  channelId  String
  userId     String
  role       ChannelRole @default(MEMBER)
  isExternal Boolean     @default(false)
  muted      Boolean     @default(false)
  joinedAt   DateTime    @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([channelId])
  @@index([userId])
  @@map("channel_members")
}

model Message {
  id          String  @id @default(cuid())
  channelId   String
  userId      String
  parentId    String? // For threads

  content     String
  attachments Json? // Future: file attachments

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  editedAt  DateTime?
  deleted   Boolean   @default(false)

  // Relations
  channel   Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id])
  parent    Message?   @relation("MessageThreads", fields: [parentId], references: [id])
  replies   Message[]  @relation("MessageThreads")
  reactions Reaction[]

  @@index([channelId, createdAt])
  @@index([parentId])
  @@map("messages")
}

model Reaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String   // e.g., "👍", "❤️", "😂"
  createdAt DateTime @default(now())

  // Relations
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  // One reaction per user per emoji per message
  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("reactions")
}
