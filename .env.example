# Database
DATABASE_URL="postgresql://user:password@localhost:5432/context?schema=public"

# Auth
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"

# App
APP_URL="http://localhost:3000"

# AI
OPENAI_API_KEY="sk-your-key"
OPENAI_MODEL="gpt-5-mini"

# Email (Postmark)
POSTMARK_API_TOKEN="your-postmark-server-token"

# Self-host limits (optional)
# Default behavior is unlimited for plan-based caps in self-host mode.
# Set to "true" to enforce FREE/PRO/ENTERPRISE plan limits.
CLAWLAB_ENABLE_PLAN_LIMITS="false"

# Optional explicit caps (work even when plan limits are otherwise unlimited)
CLAWLAB_LIMIT_PROJECTS_PER_WORKSPACE=""
CLAWLAB_LIMIT_EXTERNAL_SPACES_PER_WORKSPACE=""
CLAWLAB_LIMIT_WORKSPACES_PER_ORG=""
CLAWLAB_LIMIT_AI_CREDITS_PER_USER_PER_MONTH=""
CLAWLAB_LIMIT_UPLOAD_BYTES_PER_USER_PER_24H=""

# External stakeholder request defaults/caps
CLAWLAB_DEFAULT_MAX_IRS_PER_24H="10"
CLAWLAB_LIMIT_STAKEHOLDER_REQUESTS_PER_24H=""
