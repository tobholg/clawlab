{
  "name": "clawlab",
  "description": "Open source project management for human-agent teams",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tobholg/clawlab.git"
  },
  "homepage": "https://github.com/tobholg/clawlab",
  "bugs": {
    "url": "https://github.com/tobholg/clawlab/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "clawlab": "cli/bin/clawlab.mjs"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "prisma generate && prisma generate --schema=prisma/schema.sqlite.prisma && nuxt prepare",
    "db:push": "prisma db push",
    "db:reset": "prisma db push --force-reset",
    "prisma:generate:sqlite": "prisma generate --schema=prisma/schema.sqlite.prisma",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@nuxt/icon": "^2.2.1",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@prisma/adapter-better-sqlite3": "^7.4.1",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@vueuse/core": "^14.1.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "apexcharts": "^5.3.6",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.3",
    "jose": "^6.1.3",
    "mime-types": "^3.0.2",
    "node-pty": "^1.0.0",
    "nuxt": "^4.3.0",
    "pdfmake": "^0.3.5",
    "pg": "^8.17.2",
    "prisma": "^7.3.0",
    "sharp": "^0.34.5",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4",
    "vue3-apexcharts": "^1.10.0"
  },
  "devDependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@types/mime-types": "^3.0.1",
    "tsx": "^4.21.0"
  }
}
